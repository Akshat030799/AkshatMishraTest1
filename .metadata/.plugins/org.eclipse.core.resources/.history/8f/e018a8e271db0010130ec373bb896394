package Collection;

import java.util.ArrayList;

public class Arraylist1 {

	public static void main(String[] args) {
		ArrayList arraylIst=new ArrayList();
		
		for (int i=0;i<=10;i++) {
		arraylIst.add(i);
		}
		
		System.out.println(arraylIst);
		
		for (Object k:arraylIst) {
			
			System.out.println(k);
		}

	}

}
