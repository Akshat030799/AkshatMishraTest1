import io.github.bonigarcia.wdm.WebDriverManager;

public class JavaExcuterClick {
	public static void main(String[] args) {
	
	WebDriverManager.edgedriver().setup();
	WebDriver driver =new EdgeDriver();
	driver.get("https://www.vuse.com/");
	driver.manage().window().maximize();
	WebElement k=driver.findElement(By.xpath("//select"));
	Select s=new Select(k);
s.selectByIndex(1);

WebElement g=driver.findElement(By.xpath("//button[@id='soft-av-accept']"));
//WebDriverWait wait=new WebDriverWait(driver,Duration.ofSeconds(20));
//wait.until(ExpectedConditions.visibilityOf(g));
JavascriptExecutor jse=(JavascriptExecutor)driver;
jse.executeScript("argument[0].scrollIntoView()", g);
}
}