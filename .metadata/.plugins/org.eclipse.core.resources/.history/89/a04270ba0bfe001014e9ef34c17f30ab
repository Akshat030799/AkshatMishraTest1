package seleniumPractice;

import java.io.FileInputStream;
import java.io.IOException;

import org.apache.poi.xssf.usermodel.*;

public class ExcelFiles {

    public static void main(String[] args) throws IOException {

        FileInputStream file =
                new FileInputStream("C:\\Users\\pmmis\\eclipse-workspace\\SeleniumTestingPractice\\TestData\\QA Assignment - Sourav_Bhange.xlsx");

        XSSFWorkbook workbook = new XSSFWorkbook(file);

        // ===== Sheet 1 =====
        printSheetAsTable(workbook, "Test_Cases");

        // ===== Sheet 2 =====
        printSheetAsTable(workbook, "Bugs + Enhancements");

        workbook.close();
        file.close();
    }

    // ================= TABLE METHOD =================
    static void printSheetAsTable(XSSFWorkbook workbook, String sheetName) {

        XSSFSheet sheet = workbook.getSheet(sheetName);

        int totalRows = sheet.getLastRowNum();
        int totalCols = sheet.getRow(0).getLastCellNum();

        System.out.println("\n==============================");
        System.out.println("SHEET : " + sheetName);
        System.out.println("==============================");

        for (int r = 0; r <= totalRows; r++) {

            XSSFRow row = sheet.getRow(r);
            if (row == null) continue;

            for (int c = 0; c < totalCols; c++) {

                XSSFCell cell = row.getCell(c);

                String value = (cell == null) ? "" : cell.toString();
                System.out.printf("| %-20s ", value);
            }
            System.out.println("|");
        }
        System.out.println("==============================");
    }
}
